 drivers/hid/hid-ids.h         |   1 +
 drivers/hid/hid-playstation.c | 317 ++++++++++++++++++++++++++++++++++
 drivers/hid/hid-quirks.c      |   3 +
 6 files changed, 337 insertions(+)
 create mode 100644 drivers/hid/hid-playstation.c

