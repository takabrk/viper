+	     '$outdir/ecn_bulk.bbr'         u 1:2 t 'bbr'             w lp lw 2 pt 7 lt rgb \"#abd9e9\",\
+	     '$outdir/ecn_bulk.bbr2'  u 1:2 t 'bbr2' w lp lw 2 pt 7 lt rgb \"#2c7bb6\"\
+             \n" > $outdir/ecn_bulk_rtt.gnuplot
+
+    gnuplot -persist $outdir/ecn_bulk_rtt.gnuplot
