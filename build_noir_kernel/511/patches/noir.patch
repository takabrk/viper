+    for cc_name in dctcp bbr2 bbr; do
+	for num_flows in 1 4 10 40 100; do
+	    sumd="$indir/ecn_bulk/${cc_name}/${num_flows}/summary/"
+	    mkdir -p $sumd
+	    rm -f "${sumd}/*txt"
+	    for rep in `seq 1 10`; do
