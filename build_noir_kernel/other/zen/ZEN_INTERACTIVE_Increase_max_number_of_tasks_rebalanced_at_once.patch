From cbef2dd68b27d957d4b24ee020fd33ef5ebdf26b Mon Sep 17 00:00:00 2001
From: Steven Barrett <steven@liquorix.net>
Date: Sat, 13 Jun 2020 15:55:18 -0500
Subject: [PATCH] ZEN: INTERACTIVE: Increase max number of tasks rebalanced at
 once

Take "sysctl_sched_nr_migrate" tune from early XanMod builds of 128. As
of 5.7, XanMod uses 256 but that may affect applications that require
timely response to IRQs.
---
 init/Kconfig        | 1 +
 kernel/sched/core.c | 4 ++++
 2 files changed, 5 insertions(+)

diff --git a/init/Kconfig b/init/Kconfig
index ee99c44e26091..f2bc6c286d41b 100644
--- a/init/Kconfig
+++ b/init/Kconfig
@@ -115,6 +115,7 @@ config ZEN_INTERACTIVE
 	    Wakeup granularity.............:   1    ->   0.5  ms
 	    CPU migration cost.............:   0.5  ->   0.25 ms
 	    Bandwidth slice size...........:   5    ->   3    ms
+	    Task rebalancing threshold.....:   32   ->   128
 	    Ondemand sampling down factor..:   1    ->   5
 
 	  --- MuQSS CPU Scheduler --------------------------------
diff --git a/kernel/sched/core.c b/kernel/sched/core.c
index 2d95dc3f46444..1db4a25b6255e 100644
--- a/kernel/sched/core.c
+++ b/kernel/sched/core.c
@@ -63,7 +63,11 @@ const_debug unsigned int sysctl_sched_features =
  * Number of tasks to iterate in a single balance run.
  * Limited because this is done with IRQs disabled.
  */
+#ifdef CONFIG_ZEN_INTERACTIVE
+const_debug unsigned int sysctl_sched_nr_migrate = 128;
+#else
 const_debug unsigned int sysctl_sched_nr_migrate = 32;
+#endif
 
 /*
  * period over which we measure -rt task CPU usage in us.
